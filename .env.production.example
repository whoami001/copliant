# 生产环境配置示例

# 应用配置
APP_NAME=Compliance Hub
DEBUG=false
API_PREFIX=/api

# 数据库配置（生产环境）
DATABASE_URL=postgresql://compliance:CHANGE_ME@db:5432/compliance_hub

# JWT 配置（生产环境必须修改）
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Black Duck API 配置
BLACK_DUCK_URL=https://your-blackduck-instance.com
BLACK_DUCK_TOKEN=your-api-token-here

# 日志配置（生产环境使用 JSON 格式）
LOG_LEVEL=INFO
LOG_FORMAT=json

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 同步/异步阈值
BLACK_DUCK_SYNC_MAX_COMPONENTS=50

# SMTP 邮件配置（可选，用于通知）
# SMTP_HOST=smtp.company.com
# SMTP_PORT=587
# SMTP_USER=notifications@company.com
# SMTP_PASSWORD=CHANGE_ME

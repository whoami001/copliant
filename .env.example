# 应用配置
APP_NAME=Compliance Hub
DEBUG=true
API_PREFIX=/api

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/compliance_hub

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Black Duck API 配置
BLACK_DUCK_URL=
BLACK_DUCK_TOKEN=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=text

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 同步/异步阈值
BLACK_DUCK_SYNC_MAX_COMPONENTS=50
